Title: Search
Layout: /_Layout.cshtml
---
@using Statiq.Common
@using Statiq.Web

<style>
    .autocomplete-wrapper {
        position: relative;
        width: 100%;
    }
    .autocomplete-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #2e3141;
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-bottom-left-radius: 6px;
        border-bottom-right-radius: 6px;
        max-height: 250px;
        overflow-y: auto;
        z-index: 1000;
        display: none;
        margin-top: 1px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
    }
    .autocomplete-item {
        padding: 0.8em 1em;
        cursor: pointer;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        color: rgba(255, 255, 255, 0.8) !important;
        display: block;
        text-decoration: none !important;
        font-size: 0.95em;
        transition: background-color 0.15s, color 0.15s;
    }
    .autocomplete-item:last-child {
        border-bottom: none;
    }
    .autocomplete-item:hover, .autocomplete-item.active {
        background-color: rgba(255, 255, 255, 0.08);
        color: #ffffff !important;
    }
    
    /* Light Mode Overrides */
    body.light-theme .autocomplete-dropdown {
        background: #ffffff;
        border-color: #cbd5e1;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }
    body.light-theme .autocomplete-item {
        color: #334155 !important;
        border-bottom-color: #f1f5f9;
    }
    body.light-theme .autocomplete-item:hover, body.light-theme .autocomplete-item.active {
        background-color: #f1f5f9;
        color: #0f172a !important;
    }
</style>

<h2>Search</h2>

<section style="margin-bottom: 2em;">
    <div class="autocomplete-wrapper">
        <input type="text" id="search-input" placeholder="Type to search posts..." autofocus style="font-size: 1.15em; height: 3em; padding: 0.5em 1em; width: 100%;" autocomplete="off" />
        <div id="autocomplete-list" class="autocomplete-dropdown"></div>
    </div>
</section>

<section id="search-results-section" style="display: none;">
    <h3 class="major">Search Results</h3>
    <div id="search-results-list"></div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var searchInput = document.getElementById('search-input');
        var resultsSection = document.getElementById('search-results-section');
        var resultsList = document.getElementById('search-results-list');
        var autocompleteList = document.getElementById('autocomplete-list');
        
        var allPosts = [];
        var autocompleteMatches = [];
        var activeIndex = -1;

        // Fetch the search index metadata generated by Statiq
        fetch('/search.results.json')
            .then(function(response) { return response.json(); })
            .then(function(data) {
                // Convert dictionary object to array of objects
                allPosts = Object.keys(data).map(function(key) {
                    return data[key];
                });
                
                // If there's an active query in the URL, trigger it
                var urlParams = new URLSearchParams(window.location.search);
                var q = urlParams.get('q');
                if (q) {
                    searchInput.value = q;
                    performSearch(q);
                }
            })
            .catch(function(err) {
                console.error('Failed to load search index:', err);
                resultsList.innerHTML = '<p>Error loading search index. Please try again later.</p>';
                resultsSection.style.display = 'block';
            });

        // Track inputs for autocomplete and full search results
        searchInput.addEventListener('input', function() {
            var query = searchInput.value.trim().toLowerCase();
            updateAutocomplete(query);
        });

        // Keyboard navigation inside suggestions dropdown
        searchInput.addEventListener('keydown', function(e) {
            var items = autocompleteList.getElementsByClassName('autocomplete-item');
            
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                if (items.length > 0) {
                    activeIndex = (activeIndex + 1) % items.length;
                    setActiveItem(items);
                }
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                if (items.length > 0) {
                    activeIndex = (activeIndex - 1 + items.length) % items.length;
                    setActiveItem(items);
                }
            } else if (e.key === 'Enter') {
                if (activeIndex > -1 && activeIndex < items.length) {
                    e.preventDefault();
                    items[activeIndex].click(); // Navigate to the post
                } else {
                    // Triggers full search rendering below
                    performSearch(searchInput.value);
                    closeAutocomplete();
                }
            } else if (e.key === 'Escape') {
                closeAutocomplete();
            }
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            if (e.target !== searchInput && e.target !== autocompleteList) {
                closeAutocomplete();
            }
        });

        function updateAutocomplete(query) {
            activeIndex = -1;
            if (!query) {
                closeAutocomplete();
                return;
            }

            // Find matching posts for autocomplete list (limit to 5)
            // Searches title, link URL, and tags array
            autocompleteMatches = allPosts.filter(function(post) {
                var titleMatch = post.title && post.title.toLowerCase().indexOf(query) !== -1;
                var linkMatch = post.link && post.link.toLowerCase().indexOf(query) !== -1;
                
                var tagMatch = false;
                if (post.tags && Array.isArray(post.tags)) {
                    tagMatch = post.tags.some(function(tag) {
                        return tag.toLowerCase().indexOf(query) !== -1;
                    });
                }
                
                return titleMatch || linkMatch || tagMatch;
            }).slice(0, 5);

            if (autocompleteMatches.length === 0) {
                closeAutocomplete();
                return;
            }

            var html = '';
            autocompleteMatches.forEach(function(post, index) {
                var title = escapeHtml(post.title || 'Untitled');
                html += '<a href="' + post.link + '" class="autocomplete-item" data-index="' + index + '">' + title + '</a>';
            });

            autocompleteList.innerHTML = html;
            autocompleteList.style.display = 'block';

            // Add click events to autocomplete items
            var items = autocompleteList.getElementsByClassName('autocomplete-item');
            Array.prototype.forEach.call(items, function(item) {
                item.addEventListener('click', function(e) {
                    closeAutocomplete();
                });
            });
        }

        function setActiveItem(items) {
            Array.prototype.forEach.call(items, function(item) {
                item.classList.remove('active');
            });

            if (activeIndex > -1 && activeIndex < items.length) {
                items[activeIndex].classList.add('active');
                
                var itemOffset = items[activeIndex].offsetTop;
                var listHeight = autocompleteList.offsetHeight;
                var itemHeight = items[activeIndex].offsetHeight;

                if (itemOffset + itemHeight > autocompleteList.scrollTop + listHeight) {
                    autocompleteList.scrollTop = itemOffset + itemHeight - listHeight;
                } else if (itemOffset < autocompleteList.scrollTop) {
                    autocompleteList.scrollTop = itemOffset;
                }
            }
        }

        function closeAutocomplete() {
            autocompleteList.style.display = 'none';
            autocompleteList.innerHTML = '';
            activeIndex = -1;
        }

        function performSearch(query) {
            query = query.trim().toLowerCase();
            if (!query) {
                resultsSection.style.display = 'none';
                resultsList.innerHTML = '';
                return;
            }

            var matches = allPosts.filter(function(post) {
                var titleMatch = post.title && post.title.toLowerCase().indexOf(query) !== -1;
                var linkMatch = post.link && post.link.toLowerCase().indexOf(query) !== -1;
                
                var tagMatch = false;
                if (post.tags && Array.isArray(post.tags)) {
                    tagMatch = post.tags.some(function(tag) {
                        return tag.toLowerCase().indexOf(query) !== -1;
                    });
                }
                
                return titleMatch || linkMatch || tagMatch;
            });

            renderResults(matches, query);
        }

        function renderResults(matches, query) {
            resultsSection.style.display = 'block';
            if (matches.length === 0) {
                resultsList.innerHTML = '<p>No results found for "' + escapeHtml(query) + '".</p>';
                return;
            }

            var html = '';
            matches.forEach(function(post) {
                var title = escapeHtml(post.title || 'Untitled');
                var url = post.link || '#';
                
                html += '<section style="margin-bottom: 2em;">';
                html += '    <h3 class="major" style="margin-bottom: 0.5em;"><a href="' + url + '">' + title + '</a></h3>';
                
                // Render tags as small clickable buttons
                if (post.tags && Array.isArray(post.tags) && post.tags.length > 0) {
                    html += '    <div style="margin-top: 0.6em; margin-bottom: 0.8em; display: flex; flex-wrap: wrap; gap: 0.4em;">';
                    post.tags.forEach(function(tag) {
                        var slug = tag.toLowerCase().replace(/ /g, "-").replace(/\./g, "-");
                        html += '        <a href="/tags/' + slug + '" class="button small" style="font-size: 0.75em; padding: 0 0.8em; height: 1.8em; line-height: 1.8em; text-transform: lowercase;">' + escapeHtml(tag) + '</a>';
                    });
                    html += '    </div>';
                }
                
                html += '    <p style="font-size: 0.85em; opacity: 0.7; margin-bottom: 0.5em;">Link: <a href="' + url + '">' + url + '</a></p>';
                html += '</section>';
                html += '<hr style="margin: 1.5em 0;" />';
            });
            resultsList.innerHTML = html;
        }

        function escapeHtml(str) {
            return str
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }
    });
</script>
