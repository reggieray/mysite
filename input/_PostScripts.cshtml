<style>
    /* Styling for the active reading paragraph highlight */
    .reading-highlight {
        background-color: rgba(99, 102, 241, 0.1) !important;
        border-left: 4px solid #6366f1 !important;
        padding-left: 0.6em !important;
        border-radius: 3px;
        transition: background-color 0.25s ease, padding-left 0.25s ease, border-left-color 0.25s ease;
    }
    
    body.light-theme .reading-highlight {
        background-color: rgba(79, 70, 229, 0.06) !important;
        border-left-color: #4f46e5 !important;
    }

    /* Floating TTS Mini Player styling */
    body.light-theme #floating-tts-bar {
        background: rgba(255, 255, 255, 0.96) !important;
        border-color: #cbd5e1 !important;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08) !important;
    }
    body.light-theme #floating-tts-bar span {
        color: #334155 !important;
    }
    body.light-theme #floating-tts-bar span i {
        color: #4f46e5 !important;
    }
</style>

<!-- Floating TTS Mini-Player Panel -->
<div id="floating-tts-bar" style="position: fixed; bottom: 2em; right: 2em; background: rgba(46, 49, 65, 0.96); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 40px; padding: 0.6em 1.2em; display: none; gap: 0.8em; align-items: center; box-shadow: 0 10px 30px rgba(0,0,0,0.45); z-index: 9999; backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); transition: all 0.3s ease-in-out;">
    <span style="font-size: 0.8em; color: rgba(255,255,255,0.85); font-weight: 600; display: inline-flex; align-items: center; gap: 0.5em; letter-spacing: 0.05em; text-transform: uppercase;">
        <i class="fa fa-volume-up" style="color: #6366f1;"></i> Reading Post
    </span>
    <button id="float-play-btn" class="button small special" style="height: 2.2em; line-height: 2.2em; padding: 0 1em; font-size: 0.8em; border-radius: 20px; text-transform: none; display: inline-flex; align-items: center; gap: 0.4em; box-shadow: none;">
        <i class="fa fa-pause"></i> <span>Pause</span>
    </button>
    <button id="float-stop-btn" class="button small" style="height: 2.2em; line-height: 2.2em; padding: 0 1em; font-size: 0.8em; border-radius: 20px; text-transform: none; display: inline-flex; align-items: center; gap: 0.4em; box-shadow: none;">
        <i class="fa fa-stop"></i> <span>Stop</span>
    </button>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var synth = window.speechSynthesis;
        var hasTTS = 'speechSynthesis' in window;
        
        if (!hasTTS) return;
        
        // Main buttons (in banner)
        var controlsWrapper = document.getElementById('tts-controls-wrapper');
        var playBtn = document.getElementById('read-aloud-btn');
        var stopBtn = document.getElementById('stop-read-btn');
        
        // Floating buttons
        var floatBar = document.getElementById('floating-tts-bar');
        var floatPlayBtn = document.getElementById('float-play-btn');
        var floatStopBtn = document.getElementById('float-stop-btn');
        
        if (!controlsWrapper || !playBtn || !stopBtn || !floatBar || !floatPlayBtn || !floatStopBtn) return;
        
        // Show banner controls since Text-to-Speech is supported
        controlsWrapper.style.display = 'flex';
        
        var utterances = [];
        var currentUtteranceIndex = 0;
        var state = 'stopped'; // stopped, playing, paused
        
        // Query and return a premium natural-sounding voice if available
        function getPremiumVoice() {
            var voices = synth.getVoices();
            var targetVoice = null;
            
            // Priority list: Google US English > Microsoft/Edge Natural > Siri/Samantha Premium > English fallback
            var matches = [
                function(v) { return v.name.indexOf('Google US English') !== -1; },
                function(v) { return v.name.indexOf('Natural') !== -1 && v.lang.startsWith('en'); },
                function(v) { return v.name.indexOf('Siri') !== -1 || v.name.indexOf('Samantha') !== -1 || v.name.indexOf('Premium') !== -1; },
                function(v) { return v.lang === 'en-US'; },
                function(v) { return v.lang.startsWith('en'); }
            ];
            
            for (var i = 0; i < matches.length; i++) {
                targetVoice = voices.find(matches[i]);
                if (targetVoice) break;
            }
            
            return targetVoice;
        }

        // Populate voices asynchronously (required for Chrome/Android)
        if (synth.onvoiceschanged !== undefined) {
            synth.onvoiceschanged = getPremiumVoice;
        }
        
        function getReadableText() {
            var segments = [];
            var root = document.querySelector('#wrapper .wrapper.style2 .inner');
            if (!root) return [];
            
            var elements = root.querySelectorAll('h1, h2, h3, h4, h5, h6, p, li, blockquote');
            elements.forEach(function(el) {
                // Ignore code blocks, copy buttons, or other widgets
                if (el.closest('pre') || el.closest('code') || el.closest('button')) return;
                
                var txt = el.innerText.trim();
                if (txt) {
                    segments.push({
                        element: el,
                        text: txt
                    });
                }
            });
            return segments;
        }
        
        function speakNext() {
            clearHighlight();
            
            if (currentUtteranceIndex >= utterances.length) {
                resetTTS();
                return;
            }
            
            var utter = utterances[currentUtteranceIndex];
            
            // Apply highlight and scroll current element into center of viewport
            if (utter.domElement) {
                utter.domElement.classList.add('reading-highlight');
                utter.domElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
            
            utter.onend = function() {
                if (state === 'playing') {
                    currentUtteranceIndex++;
                    speakNext();
                }
            };
            utter.onerror = function(e) {
                console.error('Speech error:', e);
                resetTTS();
            };
            
            synth.speak(utter);
        }
        
        function startTTS() {
            synth.cancel();
            var segments = getReadableText();
            if (segments.length === 0) return;
            
            var premiumVoice = getPremiumVoice();
            
            utterances = segments.map(function(item) {
                var u = new SpeechSynthesisUtterance(item.text);
                
                if (premiumVoice) {
                    u.voice = premiumVoice;
                }
                
                u.rate = 1.0; 
                u.pitch = 1.0; 
                u.domElement = item.element; // Attach DOM node reference
                return u;
            });
            
            currentUtteranceIndex = 0;
            state = 'playing';
            updateUIState();
            
            speakNext();
        }
        
        function clearHighlight() {
            var activeHighlight = document.querySelector('.reading-highlight');
            if (activeHighlight) {
                activeHighlight.classList.remove('reading-highlight');
            }
        }
        
        function resetTTS() {
            synth.cancel();
            clearHighlight();
            state = 'stopped';
            utterances = [];
            currentUtteranceIndex = 0;
            updateUIState();
        }

        function updateUIState() {
            if (state === 'playing') {
                playBtn.innerHTML = '<i class="fa fa-pause"></i> <span>Pause</span>';
                floatPlayBtn.innerHTML = '<i class="fa fa-pause"></i> <span>Pause</span>';
                stopBtn.style.display = 'inline-flex';
                floatBar.style.display = 'flex';
            } else if (state === 'paused') {
                playBtn.innerHTML = '<i class="fa fa-play"></i> <span>Resume</span>';
                floatPlayBtn.innerHTML = '<i class="fa fa-play"></i> <span>Resume</span>';
                stopBtn.style.display = 'inline-flex';
                floatBar.style.display = 'flex';
            } else if (state === 'stopped') {
                playBtn.innerHTML = '<i class="fa fa-volume-up"></i> <span>Read Aloud</span>';
                stopBtn.style.display = 'none';
                floatBar.style.display = 'none';
            }
        }
        
        // Handle playback clicks (main button)
        playBtn.addEventListener('click', function() {
            if (state === 'stopped') {
                startTTS();
            } else if (state === 'playing') {
                synth.pause();
                state = 'paused';
                updateUIState();
            } else if (state === 'paused') {
                synth.resume();
                state = 'playing';
                updateUIState();
            }
        });
        
        // Handle stop clicks (main button)
        stopBtn.addEventListener('click', function() {
            resetTTS();
        });

        // Sync playback clicks (floating button)
        floatPlayBtn.addEventListener('click', function() {
            if (state === 'playing') {
                synth.pause();
                state = 'paused';
                updateUIState();
            } else if (state === 'paused') {
                synth.resume();
                state = 'playing';
                updateUIState();
            }
        });

        // Sync stop clicks (floating button)
        floatStopBtn.addEventListener('click', function() {
            resetTTS();
        });
        
        // Reset speech if page is unloaded/reloaded
        window.addEventListener('beforeunload', function() {
            synth.cancel();
        });
    });
</script>