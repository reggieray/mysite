@using Statiq.Common
@using Statiq.Web
@{ 
	string title = Document.GetString("Title");
	string siteTitle = Document.GetString(WebKeys.SiteTitle) ?? "Matthew Regis";
	string pageTitle = siteTitle + (string.IsNullOrWhiteSpace(title) ? string.Empty : " - " + title);
}

<!DOCTYPE HTML>
<!--
	Solid State by HTML5 UP
	html5up.net | @@ajlkn
	Free for personal and commercial use under the CCA 3.0 license (html5up.net/license)
-->
<html lang="en">
	<head>
		<title>@pageTitle</title>
		<meta charset="utf-8" />
		<link rel='icon' href='/favicon.ico' type='image/x-icon' />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="stylesheet" href="/assets/css/main.css" />
		<link rel="stylesheet" href="/assets/css/theme-switcher.css" />

		<meta name="theme-color" content="#5d2b90" />

		<!-- SEO & Social Media Card Previews -->
		<link rel="canonical" href="@(Document.GetLink(true))" />
		<meta name="description" content="@(Document.GetString("Lead") ?? "Thoughts from a software engineer, mostly tech and dotnet related.")" />
		<meta property="og:title" content="@pageTitle" />
		<meta property="og:description" content="@(Document.GetString("Lead") ?? "Thoughts from a software engineer, mostly tech and dotnet related.")" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="@(Document.GetLink(true))" />
		@if(Document.ContainsKey("Image"))
		{
			<meta property="og:image" content="@(Document.GetLink("Image", true))" />
		}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="@pageTitle" />
		<meta name="twitter:description" content="@(Document.GetString("Lead") ?? "Thoughts from a software engineer, mostly tech and dotnet related.")" />
		@if(Document.ContainsKey("Image"))
		{
			<meta name="twitter:image" content="@(Document.GetLink("Image", true))" />
		}

        @if(IsSectionDefined("PostHead"))
        {
            @RenderSection("PostHead")
        }
        
        @if(Document.ContainsKey("Image"))
		{
			<style>
				body:not(.light-theme) {
					background-image: linear-gradient(to top, rgba(46, 49, 65, 0.8), rgba(46, 49, 65, 0.8)), url(@Document.GetString("Image"));
				}
				@@media screen and (max-width: 1280px) {
					body:not(.light-theme) #banner, body:not(.light-theme) #wrapper > header {
						background-image: linear-gradient(to top, rgba(46, 49, 65, 0.8), rgba(46, 49, 65, 0.8)), url(@Document.GetString("Image"));
					}
				}
			</style>
		}
        @await Html.PartialAsync("_Head")
	</head>
	<body class="no-transition">
		<script>
			(function() {
				var theme = localStorage.getItem('theme') || 'dark';
				if (theme === 'light') {
					document.body.classList.add('light-theme');
					document.documentElement.classList.add('light-theme');
				}
			})();
		</script>

		<!-- Page Wrapper -->
			<div id="page-wrapper">
				
				<header id="header">
					<h1><a href="/">@siteTitle</a></h1>
					<nav>
						<a href="/search" class="theme-toggle-btn" aria-label="Search">
							<i class="fa fa-search"></i>
						</a>
						<a href="javascript:void(0);" id="theme-toggle" class="theme-toggle-btn" aria-label="Toggle theme">
							<i class="fa fa-adjust"></i>
						</a>
						<a href="#menu"></a>
					</nav>
				</header>

				<!-- Menu -->
				<nav id="menu">
					<div class="inner">
						<ul class="links">
							@await Html.PartialAsync("_Navbar")
						</ul>
						<a href="#" class="close">Close</a>
					</div>
				</nav>

				@if(IsSectionDefined("Header"))
				{
					@RenderSection("Header")
				}
				else
				{
					@await Html.PartialAsync("_Header")
				}

				<!-- Main -->
				<section id="wrapper">
					<section class="wrapper style2">
						<div class="inner">
							@RenderBody()
						</div>
					</section>
				
					@if(IsSectionDefined("Sections"))
					{
						@RenderSection("Sections")
					}
				</section>
				
				<!-- Footer -->
                <footer id="footer">
                    @await Html.PartialAsync("_Footer")
                </footer>
			</div>
			
			<!-- Floating TTS Mini-Player Panel -->
			<div id="floating-tts-bar" style="position: fixed; bottom: 2em; right: 2em; background: rgba(46, 49, 65, 0.96); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 40px; padding: 0.6em 1.2em; display: none; gap: 0.8em; align-items: center; box-shadow: 0 10px 30px rgba(0,0,0,0.45); z-index: 9999; backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); transition: all 0.3s ease-in-out;">
				<span style="font-size: 0.8em; color: rgba(255,255,255,0.85); font-weight: 600; display: inline-flex; align-items: center; gap: 0.5em; letter-spacing: 0.05em; text-transform: uppercase;">
					<i class="fa fa-volume-up" style="color: #6366f1;"></i> Reading Post
				</span>
				<button id="float-play-btn" class="button small special" style="height: 2.2em; line-height: 2.2em; padding: 0 1em; font-size: 0.8em; border-radius: 20px; text-transform: none; display: inline-flex; align-items: center; gap: 0.4em; box-shadow: none;">
					<i class="fa fa-pause"></i> <span>Pause</span>
				</button>
				<button id="float-stop-btn" class="button small" style="height: 2.2em; line-height: 2.2em; padding: 0 1em; font-size: 0.8em; border-radius: 20px; text-transform: none; display: inline-flex; align-items: center; gap: 0.4em; box-shadow: none;">
					<i class="fa fa-stop"></i> <span>Stop</span>
				</button>
			</div>

		    <!-- Scripts -->
			<script src="/assets/js/skel.min.js"></script>
			<script src="/assets/js/jquery.min.js"></script>
			<script src="/assets/js/jquery.scrollex.min.js"></script>
			<script src="/assets/js/util.js"></script>
            <script src="/assets/js/main.js"></script>

            @await Html.PartialAsync("_Scripts")

			<script>
				document.addEventListener('DOMContentLoaded', function() {
					// 1. Theme toggle functionality
					var toggleBtn = document.getElementById('theme-toggle');
					if (toggleBtn) {
						toggleBtn.addEventListener('click', function() {
							var isLight = document.body.classList.contains('light-theme');
							if (isLight) {
								document.body.classList.remove('light-theme');
								document.documentElement.classList.remove('light-theme');
								localStorage.setItem('theme', 'dark');
							} else {
								document.body.classList.add('light-theme');
								document.documentElement.classList.add('light-theme');
								localStorage.setItem('theme', 'light');
							}
						});
					}

					// 2. Remove transition block after page load to prevent initial flash
					setTimeout(function() {
						document.body.classList.remove('no-transition');
					}, 100);

					// 3. Global Keyboard Shortcut for Search ('/' key)
					document.addEventListener('keydown', function(e) {
						if (e.key === '/' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
							e.preventDefault();
							var searchInput = document.getElementById('search-input');
							if (searchInput) {
								searchInput.focus();
							} else {
								window.location.href = '/search';
							}
						}
					});

					// 4. Add "Copy to Clipboard" Buttons to Pre Code Blocks
					var preBlocks = document.querySelectorAll('pre');
					preBlocks.forEach(function(pre) {
						if (pre.querySelector('.copy-code-btn')) return; // Avoid duplicate buttons
						
						var button = document.createElement('button');
						button.className = 'copy-code-btn';
						button.setAttribute('aria-label', 'Copy code');
						button.innerHTML = '<i class="fa fa-copy"></i>';
						pre.appendChild(button);
						
						button.addEventListener('click', function() {
							var code = pre.querySelector('code');
							var text = code ? code.innerText : pre.innerText;
							
							navigator.clipboard.writeText(text).then(function() {
								button.innerHTML = '<i class="fa fa-check"></i>';
								button.classList.add('copied');
								setTimeout(function() {
									button.innerHTML = '<i class="fa fa-copy"></i>';
									button.classList.remove('copied');
								}, 2000);
							}).catch(function(err) {
								console.error('Failed to copy code: ', err);
							});
						});
					});

					// 5. Lazy-load all images for performance optimization
					var images = document.querySelectorAll('img');
					images.forEach(function(img) {
						if (!img.hasAttribute('loading')) {
							img.setAttribute('loading', 'lazy');
						}
					});

					// 6. Register PWA Service Worker for offline support and speed
					if ('serviceWorker' in navigator) {
						window.addEventListener('load', function() {
							navigator.serviceWorker.register('/sw.js').then(function(reg) {
								console.log('ServiceWorker registered with scope: ', reg.scope);
							}).catch(function(err) {
								console.error('ServiceWorker registration failed: ', err);
							});
						});
					}

					// 7. Back to Top smooth scroll button handler
					var backToTopBtn = document.getElementById('back-to-top');
					if (backToTopBtn) {
						window.addEventListener('scroll', function() {
							if (window.scrollY > 400) {
								backToTopBtn.style.display = 'inline-flex';
							} else {
								backToTopBtn.style.display = 'none';
							}
						});
						backToTopBtn.addEventListener('click', function() {
							window.scrollTo({ top: 0, behavior: 'smooth' });
						});
					}
				});
			</script>

			<!-- Floating Back to Top Button -->
			<button id="back-to-top" class="button small" style="position: fixed; bottom: 5.5em; right: 2.2em; display: none; z-index: 9998; border-radius: 50%; width: 2.8em; height: 2.8em; padding: 0; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(0,0,0,0.3); text-transform: none; border-color: rgba(255,255,255,0.2);">
				<i class="fa fa-chevron-up"></i>
			</button>

	</body>

</html>
